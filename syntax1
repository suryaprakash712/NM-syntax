def detect_python_code(text):\n","    patterns = [\n","        r'def\\s+\\w+\\s*\\(',\n","        r'class\\s+\\w+',\n","        r'import\\s+\\w+',\n","        r'from\\s+\\w+\\s+import',\n","        r'if\\s+.*:',\n","        r'for\\s+.*\\s+in\\s+',\n","        r'while\\s+.*:'\n","    ]\n","    return any(re.search(pattern, text) for pattern in patterns)"]},{"cell_type":"code","execution_count":5,"metadata":{"id":"6l9N7pNyHd40","executionInfo":{"status":"ok","timestamp":1772684453218,"user_tz":-330,"elapsed":3,"user":{"displayName":"Ganesan Sujith","userId":"14145286129839140935"}}},"outputs":[],"source":["def detect_python_code(text):\n","    patterns = [\n","        r'def\\s+\\w+\\s*\\(',\n","        r'class\\s+\\w+',\n","        r'import\\s+\\w+',\n","        r'from\\s+\\w+\\s+import',\n","        r'if\\s+.*:',\n","        r'for\\s+.*\\s+in\\s+',\n","        r'while\\s+.*:'\n","    ]\n","    return any(re.search(pattern, text) for pattern in patterns)"]},{"cell_type":"code","execution_count":6,"metadata":{"id":"l3TWmOt-HgbU","executionInfo":{"status":"ok","timestamp":1772684453241,"user_tz":-330,"elapsed":21,"user":{"displayName":"Ganesan Sujith","userId":"14145286129839140935"}}},"outputs":[],"source":["def check_syntax(code):\n","    try:\n","        ast.parse(code)\n","        return True, \"No syntax errors\"\n","    except SyntaxError as e:\n","        return False, f\"Syntax Error (Line {e.lineno}): {e.msg}\""]},{"cell_type":"code","execution_count":7,"metadata":{"id":"hs3cq8lGHjD0","executionInfo":{"status":"ok","timestamp":1772684453244,"user_tz":-330,"elapsed":16,"user":{"displayName":"Ganesan Sujith","userId":"14145286129839140935"}}},"outputs":[],"source":["def fix_indentation(code):\n","    code = code.replace(\"\\t\", \"    \")\n","    return \"\\n\".join(line.rstrip() for line in code.split(\"\\n\"))\n","\n","def fix_brackets(code):\n","    brackets = {\"(\": \")\", \"{\": \"}\", \"[\": \"]\"}\n","    stack = []\n","    for char in code:\n","        if char in brackets:\n","            stack.append(brackets[char])\n","        elif char in brackets.values():\n","            if stack and char == stack[-1]:\n","                stack.pop()\n","    return code + \"\".join(reversed(stack))\n","\n","def format_code(code):\n","    try:\n","        return black.format_str(code, mode=black.FileMode())\n","    except:\n","        return autopep8.fix_code(code)\n","\n","def fix_python_code(code):\n","    code = fix_indentation(code)\n","    code = fix_brackets(code)\n","    return format_code(code)"]},{"cell_type":"code","execution_count":8,"metadata":{"id":"8mJGwej3Hooc","executionInfo":{"status":"ok","timestamp":1772684453246,"user_tz":-330,"elapsed":14,"user":{"displayName":"Ganesan Sujith","userId":"14145286129839140935"}}},"outputs":[],"source":["conversation_history = []\n","\n","def reset_chat():\n","    global conversation_history\n","    conversation_history = []\n","    return \"Chat Cleared\""]},{"cell_type":"code","execution_count":9,"metadata":{"id":"0sK5RtyqHrJM","executionInfo":{"status":"ok","timestamp":1772684453289,"user_tz":-330,"elapsed":35,"user":{"displayName":"Ganesan Sujith","userId":"14145286129839140935"}}},"outputs":[],"source":["def generate_response(user_input, temperature, max_tokens, top_p):\n","    global conversation_history\n","\n","    conversation_history.append({\"role\": \"USER\", \"content\": user_input})\n","\n","    # SCENARIO 1, 2, 3 → Code Assistance\n","    if detect_python_code(user_input):\n","        valid, message = check_syntax(user_input)\n","\n","        if not valid:\n","            fixed_code = fix_python_code(user_input)\n","            explanation_prompt = f\"Explain this corrected Python code:\\n{fixed_code}\"\n","\n","            explanation = pipe(\n","                explanation_prompt,\n","                max_new_tokens=int(max_tokens),\n","                temperature=temperature,\n","                top_p=top_p,\n","                do_sample=True\n","            )[0][\"generated_text\"]\n","\n","            final_response = (\n","                f\"🔧 Syntax Issue Found:\\n{message}\\n\\n\"\n","                f\"✅ Fixed Code:\\n{fixed_code}\\n\\n\"\n","                f\"📘 Explanation:\\n{explanation}\"\n","            )\n","        else:\n","            explanation_prompt = f\"Explain this Python code clearly:\\n{user_input}\"\n","            explanation = pipe(\n","                explanation_prompt,\n","                max_new_tokens=int(max_tokens),\n","                temperature=temperature,\n","                top_p=top_p,\n","                do_sample=True\n","            )[0][\"generated_text\"]\n","\n","            final_response = f\"✅ Code is syntactically correct.\\n\\n📘 Explanation:\\n{explanation}\"\n","    else:\n","        # SCENARIO → Normal Conversation\n","        output = pipe(\n","            user_input,\n","            max_new_tokens=int(max_tokens),\n","            temperature=temperature,\n","            top_p=top_p,\n","            do_sample=True\n","        )\n","        final_response = output[0][\"generated_text\"]\n","\n","    conversation_history.append({\"role\": \"ASSISTANT\", \"content\": final_response})\n","\n","    return final_response"]},{"cell_type":"code","execution_count":10,"metadata":{"id":"21iRa5Q7Ht2k","executionInfo":{"status":"ok","timestamp":1772684453294,"user_tz":-330,"elapsed":3,"user":{"displayName":"Ganesan Sujith","userId":"14145286129839140935"}}},"outputs":[],"source":["def export_txt():\n","    filename = \"chat_history.txt\"\n","    with open(filename, \"w\") as f:\n","        for msg in conversation_history:\n","            f.write(f\"{msg['role']}: {msg['content']}\\n\\n\")\n","    return filename"]},{"cell_type":"code","execution_count":11,"metadata":{"id":"yk5fMek8HxYk","executionInfo":{"status":"ok","timestamp":1772684453303,"user_tz":-330,"elapsed":5,"user":{"displayName":"Ganesan Sujith","userId":"14145286129839140935"}}},"outputs":[],"source":["def export_pdf